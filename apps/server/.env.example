# Better Auth Secrets
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=http://localhost:3000

# CORS & Database Configuration
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AWS S3 (Staging Bucket for Video Pipeline)
S3_BUCKET=your_s3_bucket_name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_aws_access_key_id
S3_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_PUBLIC_URL=
S3_ENDPOINT=

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Email (Resend)
RESEND_API_KEY=re_xxxxxx

# Video Pipeline Configuration
PIPELINE_SECRET=your_shared_pipeline_secret_for_callbacks
R2_PUBLIC_DOMAIN=your_custom_r2_domain_if_configured (e.g. video.yourdomain.com)

# AWS Lambda APIs (obtained after deploying CDK package)
LAMBDA_TRIGGER_URL=https://xxxxxx.execute-api.us-east-1.amazonaws.com/prod/trigger
LAMBDA_STATUS_URL=https://xxxxxx.execute-api.us-east-1.amazonaws.com/prod/status
LAMBDA_API_KEY=your_apigw_api_key_value
