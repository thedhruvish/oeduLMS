    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "evlog": "^2.18.1",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@oedulms/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:",
    "wrangler": "^4.103.0"
  }
