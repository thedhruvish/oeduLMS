{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "CORS_ORIGIN",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "PIPELINE_DATABASE_URL",
    "CF_WORKER_CALLBACK_URL",
    "PIPELINE_SECRET",
    "R2_ACCOUNT_ID",
    "R2_BUCKET",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_PUBLIC_DOMAIN",
    "QUEUE_URL",
    "S3_BUCKET",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_REGION",
    "WORKER_ASSETS_BUCKET",
    "INSTANCE_PROFILE_ARN",
    "AMI_ID",
    "LAMBDA_TRIGGER_URL",
    "LAMBDA_STATUS_URL",
    "LAMBDA_API_KEY",
    "LAMBDA_CALLBACK_URL",
    "AWS_REGION",
    "CDK_DEFAULT_ACCOUNT",
    "CDK_DEFAULT_REGION",
    "KEY_PAIR_NAME",
    "R2_SECRET_NAME",
    "CHUNK_DURATION_SECONDS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "deploy": {
      "cache": false
    },
    "destroy": {
      "cache": false
    }
  }
}
