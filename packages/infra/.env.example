# Target Cloudflare R2 Bucket Information
R2_BUCKET=oedulms-video
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_SECRET_NAME=oedulms/r2-credentials

# Cloudflare Callback Config
CF_WORKER_CALLBACK_URL=https://your-server.workers.dev/api/public/video/pipeline-callback
PIPELINE_SECRET=your_shared_pipeline_secret

# Neon database URL for video state tracking table
PIPELINE_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AWS Compute & Instance settings
AMI_ID=ami-0123456789abcdef0
KEY_PAIR_NAME=your_aws_key_pair_name (optional, for debugging)

# AWS Credentials / Profile (Standard CDK environment variables)
AWS_DEFAULT_REGION=us-east-1
CDK_DEFAULT_ACCOUNT=your_aws_account_id
CDK_DEFAULT_REGION=us-east-1
