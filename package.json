{
  "name": "oedulms",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "@cloudflare/workers-types": "^4.20260621.1",
      "better-auth": "1.6.11",
      "alchemy": "^0.91.2",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @oedulms/db db:push",
    "db:studio": "turbo -F @oedulms/db db:studio",
    "db:generate": "turbo -F @oedulms/db db:generate",
    "db:migrate": "turbo -F @oedulms/db db:migrate",
    "prepare": "husky",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,css,md}\""
  },
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@oedulms/config": "workspace:*",
    "@tanstack/intent": "^0.3.5",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/node": "catalog:",
    "eslint": "^9.19.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "turbo": "^2.9.16",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": "eslint --fix"
  },
  "packageManager": "bun@1.3.14"
}
